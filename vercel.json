{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.aquilatarologa.com.br" }], "destination": "https://aquilatarologa.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "tarologaaquila.vercel.app" }], "destination": "https://aquilatarologa.com.br/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "portal-do-invisivel.vercel.app" }], "destination": "https://aquilatarologa.com.br/$1", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(cards|fonts|vendor)/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*)\\.(jpg|jpeg|png|webp|gif|svg|ico|mp4|webm|woff2|woff|ttf)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=604800" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    }
  ]
}
